 query parameter: cb","hint":"Always append ?cb={unique} where unique is a UUID/random nonce."}}}}}},"404":{"description":"Invalid or unknown chart ID (must be c1..c200).","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Error"},"examples":{"bad_id":{"value":{"error":"Unknown chart id","chartId":"c999","hint":"Use lowercase c1 through c200."}}}}}},"503":{"description":"Frame temporarily unavailable (rare).","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Error"},"examples":{"unavailable":{"value":{"error":"Frame temporarily unavailable","hint":"Retry with a new cb nonce."}}}}}}},"x-openai-isConsequential":false,"x-openai-cache-bypass":{"required":true,"rule":"Always generate a new cb nonce for every request. Never reuse an older URL.","recommendedNonce":"uuid_v4_or_random_string"}}},"/health":{"get":{"summary":"Health check","description":"Returns service health and basic uptime signal.","operationId":"getHealth","tags":["System"],"responses":{"200":{"description":"OK","content":{"application/json":{"schema":{"type":"object","additionalProperties":true}}}}},"x-openai-isConsequential":false}}},"components":{"schemas":{"Error":{"type":"object","required":["error"],"properties":{"error":{"type":"string"},"chartId":{"type":"string"},"hint":{"type":"string"}},"additionalProperties":true}}},"x-chartmap":{"description":"Embedded static reference of all 200 charts — canonical source for cold-start and offline reasoning. Symbol uses TradingView format (futures end in 1!). Interval is TradingView interval code.","total":200,"groups":["01 NQ","02 ES","03 YM","04 RTY","05 Treasuries","06 GC","07 Bonds Short-Term","08 Bonds Mid-Term","09 Bonds Long-Term","10 Curve","11 Credit","12 Dollar","13 FX Majors","14 FX Emerging","15 FX Crosses","16 Crypto","17 Crypto DeFi","18 CL","19 Energy","20 Metals","21 Base Metals","22 Agriculture","23 Macro","24 Market Breadth","25 Global","26 Emerging Markets","27 ETF Rotation","28 ETF Risk","29 Semis","